# Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_KEY=

# Google service-account JSON (paste the ENTIRE JSON on one line)
GOOGLE_CREDENTIALS=

# Calendar id the service account has access to
# (Calendar Settings > Integrate calendar > Calendar ID)
CALENDAR_ID=

# Your WhatsApp number, digits only, with country code (NO + or spaces)
# Example for Pakistan: 923001234567
PAIRING_NUMBER=92XXXXXXXXXX

# Optional
TIMEZONE=Asia/Karachi
LOG_LEVEL=silent
